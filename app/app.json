{
  "expo": {
    "name": "LayCode",
    "slug": "laycode",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "LayCode needs local network access to find your computer on the same Wi-Fi"
      }
    },
    "android": {
      "package": "com.soulchild.laycode",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#0f0f1a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "hermesEnabled": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LayCode needs photo access so you can send images to the AI.",
          "cameraPermission": "LayCode needs camera access so you can take photos and send them to the AI.",
          "microphonePermission": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "LayCode 需要相机权限以扫描配对二维码连接电脑。"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "f46f1ed2-b47e-4bdd-a955-49310b1389eb"
      }
    },
    "owner": "soulchild"
  }
}
