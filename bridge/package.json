{
  "name": "laycode-cli",
  "version": "0.1.3",
  "type": "module",
  "description": "LayCode bridge — run the desktop bridge for the LayCode mobile app",
  "keywords": [
    "laycode",
    "opencode",
    "bridge",
    "cli",
    "mobile",
    "companion"
  ],
  "homepage": "https://github.com/SoulChildTc/laycode#readme",
  "bugs": {
    "url": "https://github.com/SoulChildTc/laycode/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoulChildTc/laycode.git",
    "directory": "bridge"
  },
  "author": "SoulChild",
  "license": "MIT",
  "bin": {
    "laycode-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts start --foreground",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "start": "node dist/cli.js start",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.18.1",
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "morgan": "^1.11.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
