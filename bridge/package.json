{
  "name": "laycode-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "LayCode bridge — run the desktop bridge for the LayCode mobile app",
  "bin": {
    "laycode-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts run",
    "build": "tsc",
    "start": "node dist/cli.js run"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.1",
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.0",
    "morgan": "^1.11.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
